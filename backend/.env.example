# Server Configuration
PORT=3001
NODE_ENV=development

# Email Configuration (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME="Bingo Instance Creator"

# JWT Secret for session management
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# GitHub API Configuration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=bingo
GITHUB_BRANCH=main

# Whitelist Configuration
ADMIN_WHITELIST=admin@yourdomain.com,teacher1@school.edu,teacher2@school.edu

# Rate Limiting
OTP_RATE_LIMIT_WINDOW=15
OTP_RATE_LIMIT_MAX=3
INSTANCE_RATE_LIMIT_WINDOW=60
INSTANCE_RATE_LIMIT_MAX=5

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5174,https://yourdomain.com

# Instance Creation
MAX_INSTANCES_PER_USER=10
INSTANCE_EXPIRY_DAYS=365